# ==========================================
# 🚀 E-RENTALS FRONTEND ENVIRONMENT TEMPLATE
# ==========================================

# 📡 Live Node/Express Backend Endpoint Mount Address
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# 🌐 Absolute Frontend Canonical Domain URL (For Sitemap & Google SEO)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 🖼️ Cloudinary Cloud Name (For Next.js Image Optimization Domains)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# 💳 Razorpay Public Credentials
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
